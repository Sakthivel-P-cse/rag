#!/bin/bash

cd "/home/sakthi/projects/rag" || exit

# Ensure GROBID is running (required for PDF → TEI/text extraction)
if ! docker inspect -f '{{.State.Running}}' grobid >/dev/null 2>&1; then
    docker start grobid || docker run -d --name grobid -p 8070:8070 -p 8071:8071 lfoppiano/grobid:0.8.0
fi

sleep 3

if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

python3 multihop_rag.py "$@"
